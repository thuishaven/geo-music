{
  "name": "geo-music",
  "version": "0.0.0",
  "private": true,
  "description": "Route-ordered playlist of artists from the places you drive through (Phase 0 prototype).",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "serve": "tsx src/web/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "serve:prod": "node dist/web/server.js",
    "demos": "tsx scripts/build-demos.ts",
    "auth": "tsx scripts/spotify-auth.ts",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^2.0.6",
    "dotenv": "^16.4.5",
    "hono": "^4.12.27"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
