# Spotify app credentials — create an app at https://developer.spotify.com/dashboard
# and add the redirect URI below to the app's "Redirect URIs" list.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Loopback redirect used by the Phase 0 CLI to capture the OAuth code.
# Spotify allows http://127.0.0.1 loopback redirects (must match the dashboard exactly).
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Spotify market (ISO 3166-1 alpha-2) used to pick playable top tracks.
SPOTIFY_MARKET=NL

# --- Tuning (optional; sensible defaults below) ---
# Distance between sampled waypoints along the route, in kilometers.
WAYPOINT_INTERVAL_KM=50
# Hard cap on number of distinct places to keep a prototype run short
# (MusicBrainz + Nominatim are rate-limited to ~1 req/s).
MAX_PLACES=12
# Playlist length: total play time aims for the drive time × this scale.
# 1.0 ≈ matches the drive; 0.8 ≈ a bit shorter; 1.2 ≈ a bit longer.
ROUTE_DURATION_SCALE=1.0
# How many local artists to consider per place (breadth before depth).
ARTIST_CANDIDATES_PER_PLACE=25
# Drop artists below this Spotify popularity (0-100) to cut obscure noise.
MIN_ARTIST_POPULARITY=25
# Drop individual tracks below this Spotify popularity (novelty/narration cuts).
MIN_TRACK_POPULARITY=20
# Cap on tracks taken from a single artist, so no one act dominates a place.
MAX_TRACKS_PER_ARTIST=2
# Classical/opera artists allowed per segment. 0 = exclude classical entirely
# (default); raise it if you want some classical back in.
MAX_CLASSICAL_PER_SEGMENT=0
# When strict name-matching fails, fall back to the artist's MusicBrainz-stored
# Spotify link (exact). Bounded per segment (each lookup is rate-limited).
USE_MB_LINKS=true
MAX_LINK_LOOKUPS=6

# Contact string embedded in the User-Agent for OSRM/Nominatim/MusicBrainz,
# per their usage policies. Use a real email or repo URL.
CONTACT=geo-music (https://github.com/thuishaven/geo-music)
